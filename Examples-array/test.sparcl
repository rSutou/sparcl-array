sig testf06 : rev a -o ((), rev a)
def testf06 x = ((), x)


sig testf07 : (a -> rev ()) -> rev ()
def testf07 f = rev ()

sig testf08 : (a -> rev ()) -o (a -> rev ())
def testf08 f = f

sig testf09 : rev (a -> rev ()) -o rev (a -> rev ())
def testf09 (rev f) = f

-- sig testf09 : rev (() -> rev ()) -o rev ()
-- def testf09 (rev f) = f ()

sig testf09 : rev (() -> rev ()) -o rev ((() -> rev ()) ,())
def testf09 (rev f) = pin f (\f' -> f' ())

sig testf10 : rev a -o ((), rev a)
def testf10 x = ((), x)

sig testf11 : a -> ()
def testf11 x = ()

sig testf12 : a -> rev ()
def testf12 x = rev ()


