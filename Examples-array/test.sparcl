

data Nat = Z | S Nat 


def fwd f = case unlift f of (x, _) -> x end 
def bwd f = case unlift f of (_, x) -> x end 


sig isZ : Nat -> Bool
def isZ Z = True
	  | _ = False

sig add : Nat -> rev Nat -o rev Nat
def add Z     y = y
	  | (S x) y = rev S (add x y)

sig mul : Nat -> rev Nat -o rev Nat
def mul z (rev Z)   = rev Z with isZ
	  | z (rev S y) = add z (mul z y) 

sig isEven : Nat -> Bool
def isEven Z = True
		| (S Z) = False
		| (S (S x)) = isEven x



sig ffun : rev Nat -o (Nat , rev Nat)
def ffun n = (Z, n)


sig testf0 : rev a -o rev a
def testf0 (rev a) = a

sig testf01 : a -o a
def testf01 a = a

sig testf02 : a -> a
def testf02 a = a

-- sig testf02 : ((), ()) -o ()
-- def testf02 (x, y) = x

sig testf03 : ((), ()) -o ()
def testf03 (x, ()) = x

sig testf04 : ((), ()) -o rev ()
def testf04 ((), ()) = rev ()

sig testf05 : ((), ()) -> rev ()
def testf05 ((), ()) = rev ()

-- 
-- sig testf06 : rev () -o ()
